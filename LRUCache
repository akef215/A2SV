class Node:
    def __init__(self, key, val):
        self.key = key
        self.val = val
        self.next = None
        self.prev = None

class LRUCache:
    def __init__(self, capacity):
        self.capacity = capacity
        self.cash = {}
        self.head = Node(-1, -1)
        self.tail = Node(-1, -1)
        self.head.next = self.tail
        self.tail.prev = self.head

    def deleteNode(self, p):
        p.prev.next = p.next
        p.next.prev = p.prev

    def addNode(self, newnode):
        temp = self.head.next
        self.head.next = newnode
        newnode.prev = self.head
        newnode.next = temp
        temp.prev = newnode

    def get(self, key):
        if key not in self.cash:
            return -1

        p = self.cash[key]
        self.deleteNode(p)
        self.addNode(p)
        self.cash[key] = self.head.next
        return self.head.next.val

    def put(self, key, value):
        if key in self.cash:
            c = self.cash[key]
            self.deleteNode(c)
            c.val = value
            self.addNode(c)
            self.cash[key] = self.head.next
        else:
            if len(self.cash) == self.capacity:
                prev = self.tail.prev
                self.deleteNode(prev)
                l = Node(key, value)
                self.addNode(l)
                del self.cash[prev.key]
                self.cash[key] = self.head.next
            else:
                l = Node(key, value)
                self.addNode(l)
                self.cash[key] = self.head.next

