class RecentCounter(object):

    def __init__(self):
        self.call = []
        

    def ping(self, t):
        """
        :type t: int
        :rtype: int
        """
        self.call.append(t)
        while t - self.call[0] > 3000:
            self.call.pop(0)

        return len(self.call)      


