class Solution(object):
    def reductionOperations(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        nums.sort()
        n = len(nums)
        ans = 0
        for i in range(n-1,0,-1):
            if nums[i-1] != nums[i]:
                ans += n - i
        return ans
