class Solution(object):
    def countVowelSubstrings(self, word):
        vowels = set("aeiou")
        n = len(word)
        res = 0

        for i in range(n):
            seen = set()
            for j in range(i, n):
                if word[j] not in vowels:
                    break
                seen.add(word[j])
                if len(seen) == 5:
                    res += 1

        return res
