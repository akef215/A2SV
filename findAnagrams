class Solution(object):
    def findAnagrams(self, s, p):
        out = []
        p_sorted = sorted(p)

        sub = list(s[:len(p)])

        if sorted(sub) == p_sorted:
            out.append(0)

        for i in range(1, len(s) - len(p) + 1):
            sub.pop(0)
            sub.append(s[i + len(p) - 1])

            if sorted(sub) == p_sorted:
                out.append(i)

        return out
