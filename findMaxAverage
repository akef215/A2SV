class Solution(object):
    def findMaxAverage(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: float
        """
        sum_ = 0 
        for i in range(k):
            sum_ += nums[i]
        max_avg = sum_ / float(k)
        for i in range(1, len(nums) - k + 1):
            sum_ += nums[i+k-1] - nums[i-1] 
            max_avg = max(max_avg, sum_ / float(k))
        return max_avg    
        
