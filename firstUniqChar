class Solution(object):
    def firstUniqChar(self, s):
        """
        :type s: str
        :rtype: int
        """
        count = {}
        for i, c in enumerate(s):
            count.setdefault(c, []).append(i)
        ret = -1  
        sus = []  
        for key in count:
            if len(count[key]) == 1:
                sus.extend(count[key])
        if len(sus) > 0:
            ret = min(sus)
        return ret                
