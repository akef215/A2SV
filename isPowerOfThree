class Solution:
    def isPowerOfThree(self, n: int) -> bool:
        if n == 0:
            return False
        r = 0
        while r == 0 and n != 1:
            r = n % 3
            n = n // 3
            print(r, n)
        if r == 0:
            return True
        else:
            return False         
