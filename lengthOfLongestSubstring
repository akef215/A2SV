class Solution(object):
    def lengthOfLongestSubstring(self, s):
        """
        :type s: str
        :rtype: int
        """
        max_l = 0
        count = 0
        substring = ""
        start = 0
        i = 0
        while i < len(s):
            if s[i] in substring:
                if max_l < count:
                    max_l = count

                i = start + substring.find(s[i]) + 1
                if i >= len(s):
                    break
                start = i
                count = 1
                substring = s[i]
            else:
                substring += s[i]
                count += 1
            i += 1

        return max(max_l, count)    
