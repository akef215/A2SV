class Solution(object):
    def nextGreaterElements(self, nums):
        """
        :type nums: List[int]
        :rtype: List[int]
        """
        n = len(nums)
        if n == 0:
            return []
        res = [-1] * n
        for i in range(n):
            for step in range(1, n):
                idx = (i + step) % n
                if nums[idx] > nums[i]:
                    res[i] = nums[idx]
                    break
        return res        
