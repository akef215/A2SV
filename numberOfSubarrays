class Solution(object):
    def numberOfSubarrays(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        count = {0: 1}
        curr = 0
        res = 0

        for num in nums:
            curr += num % 2  # 1 if odd, 0 if even
            
            if curr - k in count:
                res += count[curr - k]
            
            count[curr] = count.get(curr, 0) + 1

        return res
