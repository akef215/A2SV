# Definition for singly-linked list.
# class ListNode(object):
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution(object):
    def pairSum(self, head):
        """
        :type head: Optional[ListNode]
        :rtype: int
        """
        slow, fast = head, head.next
        
        while fast and fast.next:
            slow = slow.next
            fast = fast.next.next
        
        fast = slow.next
        slow.next = None 
        
        prev = None
        while fast:
            tmp = fast.next       
            fast.next = prev      
            prev = fast           
            fast = tmp            

        ans = 0  

        while prev: 
            ans = max(prev.val + head.val, ans) 
            prev = prev.next
            head = head.next
        
        return ans
