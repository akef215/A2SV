class Solution(object):
    def pancakeSort(self, arr):
        """
        :type arr: List[int]
        :rtype: List[int]
        """
        x = len(arr)
        k = []
        for i in range(x):
            max_ = max(arr[:x-i])
            max_idx = arr.index(max_) + 1
            arr[:max_idx] = reversed(arr[:max_idx])
            k.append(max_idx)

            arr[:x-i] = reversed(arr[:x-i])
            k.append(x - i)
        return k 
