class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        ans = [[1]]
        prev = [1]
        for i in range(numRows - 1):
            sub = [1]
            for j in range(i):
                sub.append(prev[j+1] + prev[j])
            sub.append(1)
            ans.append(sub)
            prev = sub
        return ans
